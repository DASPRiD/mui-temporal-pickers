{
  "name": "mui-temporal-pickers",
  "version": "1.1.3",
  "description": "A small utility library providing Temporal support for MUI X Date and Time Pickers",
  "author": "Ben Scholzen 'DASPRiD'",
  "keywords": [
    "mui",
    "x-date-pickers",
    "date-picker",
    "time-picker",
    "date-time-picker",
    "temporal",
    "TypeScript"
  ],
  "license": "BSD-2-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DASPRiD/mui-temporal-pickers.git"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist/**/*"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "demo": "vite",
    "build": "tsc -p tsconfig.build.json",
    "format": "biome format . --write",
    "check": "biome check . --write"
  },
  "peerDependencies": {
    "@mui/x-date-pickers": "^8.5.2 || ^9.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "dependencies": {
    "temporal-extra": "^1.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9.0.0",
    "@mui/x-date-pickers": "^9.0.0",
    "@tsconfig/node22": "^22.0.5",
    "@tsconfig/vite-react": "^7.0.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "c8": "^11.0.0",
    "lefthook": "^2.1.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "temporal-polyfill": "^0.3.2",
    "temporal-spec": "^0.3.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
